generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id             String   @id @default(cuid())
  name           String   @unique
  status         String   @default("ACTIVE")
  subscriptionId String?
  users          User[]
  events         Event[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String
  role           String        @default("ATTENDEE")
  status         String        @default("PENDING")
  organizationId String?
  
  // Relations
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Event {
  id             String       @id @default(cuid())
  name           String
  description    String?
  organizationId String
  startTime      DateTime
  endTime        DateTime
  latitude       Float?
  longitude      Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model AuditLog {
  id             String       @id @default(cuid())
  action         String
  targetType     String
  targetId       String
  actorId        String
  details        String?
  createdAt      DateTime     @default(now())
}

model FeatureToggle {
  id             String       @id @default(cuid())
  key            String       @unique
  isEnabled      Boolean      @default(false)
  description    String?
  updatedAt      DateTime     @updatedAt
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String       @unique
  planLevel      String       @default("TRIAL") // TRIAL, PROFESSIONAL, ENTERPRISE
  status         String       @default("ACTIVE")
  mrrAmount      Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SupportTicket {
  id             String       @id @default(cuid())
  tenantId       String
  subject        String
  priority       String       @default("LOW") // LOW, HIGH, CRITICAL
  status         String       @default("OPEN")
  createdAt      DateTime     @default(now())
}

model SystemNotification {
  id             String       @id @default(cuid())
  message        String
  type           String       @default("INFO") // INFO, URGENT
  createdAt      DateTime     @default(now())
}

model GlobalPlatformConfig {
  id             String       @id @default(cuid())
  key            String       @unique
  value          String
  updatedAt      DateTime     @updatedAt
}
