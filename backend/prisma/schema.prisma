generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id             String   @id @default(cuid())
  name           String   @unique
  status         String   @default("ACTIVE")
  subscriptionId String?
  users          User[]
  events         Event[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String
  phone          String?
  emergencyContact String?
  bloodType      String?
  role           String        @default("ATTENDEE")
  status         String        @default("PENDING")
  organizationId String?

  // Relations
  organization      Organization?      @relation(fields: [organizationId], references: [id])
  checkIns          EventCheckIn[]
  incidents         Incident[]
  eventRoles        EventPersonnel[]
  channelMemberships ChannelMember[]
  geoExceptions     GeoFenceException[] @relation("GeoFenceSubject")
  geoGranted        GeoFenceException[] @relation("GeoFenceGranter")
  accessCodesCreated EventAccessCode[]  @relation("AccessCodeCreator")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Event {
  id             String       @id @default(cuid())
  name           String
  description    String?
  organizationId String
  startTime      DateTime
  endTime        DateTime
  latitude       Float?
  longitude      Float?
  geoBoundary    String?      // JSON-encoded polygon coords [[lat,lng],...]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id])
  checkIns       EventCheckIn[]
  incidents      Incident[]
  personnel      EventPersonnel[]
  channels       CommunicationChannel[]
  geoExceptions  GeoFenceException[]
  accessCodes    EventAccessCode[]
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  actorId    String
  details    String?
  createdAt  DateTime @default(now())
}

model FeatureToggle {
  id          String   @id @default(cuid())
  key         String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
}

model Subscription {
  id             String   @id @default(cuid())
  organizationId String   @unique
  planLevel      String   @default("TRIAL")
  status         String   @default("ACTIVE")
  mrrAmount      Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SupportTicket {
  id        String   @id @default(cuid())
  tenantId  String
  subject   String
  priority  String   @default("LOW")
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}

model SystemNotification {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("INFO")
  createdAt DateTime @default(now())
}

model GlobalPlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model EventCheckIn {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  direction String   @default("IN")
  timestamp DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  eventId     String
  reporterId  String
  category    String   @default("GENERAL")
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event    Event @relation(fields: [eventId], references: [id])
  reporter User  @relation(fields: [reporterId], references: [id])
}

model EventPersonnel {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  zone      String?
  role      String   @default("VOLUNTEER")
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model CommunicationChannel {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  createdAt DateTime @default(now())

  event   Event           @relation(fields: [eventId], references: [id])
  members ChannelMember[]
}

// ─── NEW: PTT group members ───
model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel CommunicationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User                 @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
}

// ─── Volunteer Event Access Codes ───
model EventAccessCode {
  id        String    @id @default(cuid())
  code      String    @unique
  eventId   String
  createdBy String
  maxUses   Int       @default(100)
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator User  @relation("AccessCodeCreator", fields: [createdBy], references: [id])
}
model GeoFenceException {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  grantedBy String
  reason    String?
  grantedAt DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id])
  subject User  @relation("GeoFenceSubject", fields: [userId], references: [id])
  granter User  @relation("GeoFenceGranter", fields: [grantedBy], references: [id])

  @@unique([eventId, userId])
}
